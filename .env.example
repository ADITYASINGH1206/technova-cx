# 🚀 TechNova CX - Environment Variables Template
# Do NOT place real API keys or tokens in this file!
# Copy this file to `.env.local` and replace the placeholder values.

# Google Gemini Configuration
# Get your key from: https://aistudio.google.com/
GEMINI_API_KEY="your_google_ai_studio_api_key_here"

# Supabase Configuration
# Get these from your Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_public_anon_key_here"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key_here"
